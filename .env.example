# OpenAI-compatible API settings.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini

# AnkiConnect endpoint.
# Local runs and Docker Compose both use host Anki at 127.0.0.1:8765.
ANKICONNECT_URL=http://127.0.0.1:8765

# Local preferences file.
SETTINGS_FILE=./out/settings/settings.json

# Target-word highlight color used in generated Sentence HTML.
SENTENCE_HIGHLIGHT_COLOR=#00557f

# Logging. (DEBUG, INFO, WARN, ERROR)
LOGGER_LEVEL=INFO
LOGGER_FOLDER=./out/logs
